# ============================================================
# intranet-quiz-platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
#
# Docker Compose usage:
#   cp .env.example .env
#   # Edit .env, then:
#   docker compose up -d
#
# Bare-metal usage:
#   Copy .env to the project root, then run `uv run server.py`.

# ------------------------------------------------------------
# PostgreSQL (REQUIRED)
# ------------------------------------------------------------
# Password for the quizparty database user.
# Used by Docker Compose to set up the DB container AND by
# the app to connect to it. Must match in both places.
POSTGRES_PASSWORD=xv8!LB_ZcL

# Full database connection URL.
# Docker Compose overrides this automatically to point at the
# `db` container. For bare-metal, set it explicitly:
#   DATABASE_URL=postgresql://quizparty:<password>@localhost:5432/quizparty
# Leave blank if running with Docker Compose (it injects the value).
DATABASE_URL=

# ------------------------------------------------------------
# Auth — JWT (REQUIRED)
# ------------------------------------------------------------
# Secret key for signing HS256 JWTs. Generate a strong value:
#   openssl rand -hex 64
JWT_SECRET=948d55e38d5dcd42b64287b6dde2f7a4f63fe43de2a4bad246caaf736a8e12aa6de27935020b54d83fe8a8949cc94ef6496500d6bbc4fe4234f44b1df5af5352

# Teacher token lifetime in hours (default: 12)
JWT_TEACHER_TTL_HOURS=12

# ------------------------------------------------------------
# App (REQUIRED for first-run bootstrap)
# ------------------------------------------------------------
# Email of the super-admin account created by db/bootstrap_admin.py
ADMIN_DEFAULT_EMAIL=webmaster@marconirovereto.it

# Port the app listens on inside Docker (default: 5001).
# Maps to the host port: "${APP_PORT:-5001}:5001" in compose.yaml.
# APP_PORT=5001

# Base directory for uploaded quiz images (set automatically in Docker).
# For bare-metal, override if you want images outside the project root:
# IMAGES_BASE=/opt/quizparty/images

# ------------------------------------------------------------
# Google Workspace Sync (optional — enables /api/super-admin/sync)
# ------------------------------------------------------------
# Absolute path to the service-account JSON key file.
# Must be readable by the app process / container.
# Example: /opt/quizparty/.secrets/sa.json
GOOGLE_SA_KEY_PATH=

# The Google Workspace admin email the service account impersonates
# (requires domain-wide delegation).
GOOGLE_DELEGATED_SUBJECT=admin@marconirovereto.it

# Your Google Workspace domain
GOOGLE_DOMAIN=marconirovereto.it

# Google Group whose members are provisioned as teachers.
# Members of all other groups that match GOOGLE_CLASS_GROUP_PREFIX
# are provisioned as students.
GOOGLE_TEACHER_GROUP=docenti@marconirovereto.it

# Prefix for Google Groups that represent classes.
# Example: a group "class-5CI" → class name "5CI".
GOOGLE_CLASS_GROUP_PREFIX=class-

# ------------------------------------------------------------
# Email — send quiz results to students (optional)
# ------------------------------------------------------------
# Leave EMAIL_SENDER blank to disable all email functionality.

EMAIL_SENDER=your.email@example.com

# For Gmail: generate an App Password at
# https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your_app_password_here

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ------------------------------------------------------------
# LLM-based open question evaluation (optional)
# ------------------------------------------------------------
# Set USE_LLM_EVAL=1 to enable automatic grading of open questions
# via a language model. Leave at 0 to use keyword matching only.
USE_LLM_EVAL=1

# Model ID passed to the `llm` library. Format depends on the plugin:
#   OpenAI (built-in):         gpt-4o-mini
#   Anthropic (llm-anthropic): claude-3-5-haiku-20241022
#   Ollama local (llm-ollama): ollama/llama3.2   (no API key needed)
LLM_MODEL=gpt-4o-mini

# API keys — each plugin reads its own variable automatically:
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# Ollama needs no key — just run `ollama serve` locally.

# Install plugins: uv add llm-anthropic  /  uv add llm-ollama
# Plugin directory: https://llm.datasette.io/en/stable/plugins/directory.html

# Retry tuning for LLM calls
LLM_RETRIES=2
LLM_BACKOFF_FACTOR=0.5
