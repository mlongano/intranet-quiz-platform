# ============================================
# Quiz Application Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# Admin Authentication
# --------------------------------------------
# Password for accessing admin panel
# REQUIRED - Application will not start without this
ADMIN_PW=your_admin_password_here

# --------------------------------------------
# Email Configuration (for sending quiz results)
# --------------------------------------------
# Email address used as sender for quiz result emails
# Default: empty string (email functionality disabled)
EMAIL_SENDER=your.email@example.com

# App password for email account (for Gmail, generate at https://myaccount.google.com/apppasswords)
# Default: empty string (email functionality disabled)
EMAIL_PASSWORD=your_app_password_here

# SMTP server hostname
# Default: smtp.gmail.com
SMTP_SERVER=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
# Default: 587
SMTP_PORT=587

# --------------------------------------------
# PostgreSQL Database Configuration (if using PostgreSQL)
# --------------------------------------------
# Database name
# Default: none (must be set if using PostgreSQL)
DB_NAME=quizzes

# Database user
# Default: none (must be set if using PostgreSQL)
DB_USER=postgres

# Database password
# Default: none (must be set if using PostgreSQL)
DB_PASSWORD=your_db_password_here

# Database host
# Default: localhost
DB_HOST=localhost

# Database port
# Default: 5432
DB_PORT=5432

# Full database connection string (automatically constructed from above values)
# This is typically auto-generated from the DB_* variables above
# You can also set it manually if needed
CONNECTION=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --------------------------------------------
# File Paths (optional overrides)
# --------------------------------------------
# Most file paths are hardcoded in utils.py and don't use environment variables.
# Only SCORE_FILE can be overridden via environment variable.

# Path to scores file
# Default: ./scores.jsonc
# SCORE_FILE=./scores.jsonc

# NOTE: The following paths are HARDCODED in utils.py and CANNOT be changed via .env:
# - QUEST_FILE = 'questions.jsonc'
# - STUDENTS_FILE = 'students.jsonc'
# - QUIZ_FOLDER = 'quizzes'
# - IMAGES_FOLDER = 'images'
# - BANKS_BASE = 'banks'
# - QUESTION_BANK_FOLDER = 'banks/question_bank'
# - SCORES_BANK_FOLDER = 'banks/scores_bank'
# - STUDENTS_BANK_FOLDER = 'banks/students_bank'
#
# To change these paths, edit utils.py directly.

# --------------------------------------------
# Git Cloud Sync Configuration (optional)
# --------------------------------------------
# Enable cloud synchronization for banks directory
# All three banks (questions, scores, students) are synced together

# Remote Git repository URL for banks
# Example: https://github.com/username/quiz-banks-data.git
# Default: empty (cloud sync disabled)
BANKS_GIT_REMOTE=

# Git username for commits
# Example: John Doe
# Default: empty
BANKS_GIT_USERNAME=

# Personal access token or app password for Git authentication
# For GitHub: Generate at https://github.com/settings/tokens
# For GitLab: Generate at https://gitlab.com/-/profile/personal_access_tokens
# Requires 'repo' scope
# Default: empty (cloud sync disabled)
BANKS_GIT_TOKEN=


# --------------------------------------------
# LLM-based open question evaluation
# --------------------------------------------
# Enable LLM evaluation for open questions (1 = enabled, 0 = disabled)
USE_LLM_EVAL=0

# Model ID passed to the `llm` library. The format depends on the installed plugin:
#   OpenAI (built-in):        LLM_MODEL=gpt-4o-mini
#   Anthropic (llm-anthropic): LLM_MODEL=claude-3-5-haiku-20241022
#   Ollama local (llm-ollama): LLM_MODEL=ollama/llama3.2   (no API key needed)
LLM_MODEL=gpt-4o-mini

# API keys — each plugin reads its own variable automatically:
OPENAI_API_KEY=your-openai-api-key-here       # used by built-in OpenAI models
ANTHROPIC_API_KEY=your-anthropic-api-key-here  # used by llm-anthropic
DEEPSEEK_API_KEY=your-deepseek-api-key-here    # used by llm-deepseek
# Ollama needs no key — just run `ollama serve` locally

# Install plugins with: uv add llm-anthropic   /   uv add llm-ollama
# Full plugin list: https://llm.datasette.io/en/stable/plugins/directory.html

# Request tuning
# Number of retries on transient errors (default 2)
LLM_RETRIES=2
# Base backoff factor in seconds for exponential backoff (default 0.5)
LLM_BACKOFF_FACTOR=0.5

# Additional notes:
# - Keep API keys out of version control. Use a local .env file or your environment to set these.
# - If you enable LLM evaluation, consider rate limits and cost.

# --------------------------------------------
# Frontend Dashboard Configuration
# --------------------------------------------
# Group name to exclude from student/submission counts and statistics in the dashboard.
# Students belonging to this group (e.g. the teacher's own account) are hidden from
# all dashboard counters and score statistics.
# This is a Vite build-time variable (prefix VITE_) — set it in frontend/.env or here.
# Default: Theacher
VITE_EXCLUDED_GROUP=Theacher
