# Example environment variables for LLM-based open question evaluation
# Enable LLM evaluation for open questions (1 = enabled, 0 = disabled)
USE_LLM_EVAL=0
# Choose provider: 'openai' or 'google'
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=your-openai-api-key-here
# Optional: model (e.g., gpt-4, gpt-4o, gpt-3.5-turbo)
LLM_MODEL=gpt-3.5-turbo

# Google Gemini settings
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key-here

# Request tuning
# Number of retries on transient errors (default 2)
LLM_RETRIES=2
# Base backoff factor in seconds for exponential backoff (default 0.5)
LLM_BACKOFF_FACTOR=0.5
# Timeout in seconds for each LLM request (default 10)
LLM_TIMEOUT_SEC=10

# Additional notes:
# - Keep API keys out of version control. Use a local .env file or your environment to set these.
# - If you enable LLM evaluation, consider rate limits and cost.
